<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/uni_title"
            android:textColor="@color/text_bright"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/uni_subtitle"
            android:textColor="@color/text_dim"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/uni_protocol_label"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/uniProtocol"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/panel_bg"
            android:popupBackground="@color/panel" />

        <!-- Protocol address / command -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/uni_addr_cmd_label"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/uniAddr"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/panel_bg"
                android:hint="@string/uni_addr_hint"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/text_bright"
                android:textColorHint="@color/text_dim" />

            <EditText
                android:id="@+id/uniCmd"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/panel_bg"
                android:hint="@string/uni_cmd_hint"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/text_bright"
                android:textColorHint="@color/text_dim" />
        </LinearLayout>

        <!-- Pronto -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/uni_pronto_label"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/uniPronto"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/panel_bg"
            android:gravity="top"
            android:hint="@string/uni_pronto_hint"
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:textColor="@color/accent"
            android:textColorHint="@color/text_dim"
            android:textSize="11sp" />

        <!-- Raw -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/uni_raw_label"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/uniRaw"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/panel_bg"
            android:gravity="top"
            android:hint="@string/uni_raw_hint"
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:textColor="@color/accent"
            android:textColorHint="@color/text_dim"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/uniRawCarrier"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/panel_bg"
            android:hint="@string/uni_raw_carrier_hint"
            android:inputType="number"
            android:padding="12dp"
            android:textColor="@color/text_bright"
            android:textColorHint="@color/text_dim" />

        <CheckBox
            android:id="@+id/uniShotgun"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/uni_shotgun_label"
            android:textColor="@color/text_bright" />

        <Button
            android:id="@+id/uniSend"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_sync"
            android:stateListAnimator="@null"
            android:text="@string/uni_send"
            android:textColor="@color/text_bright"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/uniStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/panel_bg"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:text="@string/uni_status_placeholder"
            android:textColor="@color/accent"
            android:textSize="11sp" />
    </LinearLayout>
</ScrollView>
