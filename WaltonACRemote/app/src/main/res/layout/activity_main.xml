<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <com.emran.waltonac.AcDisplayView
            android:id="@+id/displayView"
            android:layout_width="match_parent"
            android:layout_height="330dp" />

        <!-- Power / Sync -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPower"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_power"
                android:stateListAnimator="@null"
                android:text="@string/power_off"
                android:textColor="@color/text_bright"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSync"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_sync"
                android:stateListAnimator="@null"
                android:text="@string/sync"
                android:textColor="@color/text_bright"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Protocol selection / auto-detect -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/protocol_title"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/protocolContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal" />

        <Button
            android:id="@+id/btnFinder"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/btn_sync"
            android:stateListAnimator="@null"
            android:text="@string/finder_button"
            android:textColor="@color/text_bright"
            android:textStyle="bold" />

        <!-- Temperature -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/panel_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <Button
                android:id="@+id/btnTempMinus"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/minus"
                android:textColor="@color/text_bright"
                android:textSize="22sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.4"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/temp_placeholder"
                    android:textColor="@color/accent"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/set_temp_label"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnTempPlus"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/plus"
                android:textColor="@color/text_bright"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- Mode / Fan / Turbo / Light / Sleep -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMode"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_margin="3dp"
                android:layout_weight="1.2"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/mode"
                android:textColor="@color/option_text"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnFan"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_margin="3dp"
                android:layout_weight="1.2"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/fan"
                android:textColor="@color/option_text"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnTurbo"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/turbo"
                android:textColor="@color/option_text"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnLight"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/light"
                android:textColor="@color/option_text"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnSleep"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/sleep"
                android:textColor="@color/option_text"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Vertical (up/down) swing -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/vswing_title"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/vSwingContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/panel_bg"
            android:orientation="vertical"
            android:padding="6dp" />

        <!-- Horizontal: independent left / right vane groups -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/hswing_title"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/panel_bg"
            android:orientation="horizontal"
            android:padding="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/left_vanes"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <LinearLayout
                    android:id="@+id/leftZoneContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="4dp"
                android:background="@color/divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/right_vanes"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <LinearLayout
                    android:id="@+id/rightZoneContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>

        <!-- Room temperature -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <Button
                android:id="@+id/btnRoomMinus"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/minus"
                android:textColor="@color/text_bright"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.6"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtRoom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/temp_placeholder"
                    android:textColor="@color/text_bright"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/room_temp_label"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnRoomPlus"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/plus"
                android:textColor="@color/text_bright"
                android:textSize="18sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="18dp"
            android:text="@string/footer_note"
            android:textColor="@color/text_dim"
            android:textSize="11sp" />
    </LinearLayout>
</ScrollView>
