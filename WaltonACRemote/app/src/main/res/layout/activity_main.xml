<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <com.emran.waltonac.AcDisplayView
            android:id="@+id/displayView"
            android:layout_width="match_parent"
            android:layout_height="330dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPower"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_power"
                android:stateListAnimator="@null"
                android:text="@string/power_off"
                android:textColor="@color/text_bright"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSync"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/btn_sync"
                android:stateListAnimator="@null"
                android:text="@string/sync"
                android:textColor="@color/text_bright"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Temperature -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/panel_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <Button
                android:id="@+id/btnTempMinus"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/minus"
                android:textColor="@color/text_bright"
                android:textSize="22sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.4"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/temp_placeholder"
                    android:textColor="@color/accent"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/set_temp_label"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnTempPlus"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/plus"
                android:textColor="@color/text_bright"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- Mode / Fan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMode"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:gravity="center"
                android:lines="2"
                android:padding="0dp"
                android:stateListAnimator="@null"
                android:text="@string/mode"
                android:textColor="@color/option_text"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnFan"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:gravity="center"
                android:lines="2"
                android:padding="0dp"
                android:stateListAnimator="@null"
                android:text="@string/fan"
                android:textColor="@color/option_text"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Swing -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/swing_title"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnVSwing"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/vswing"
                android:textColor="@color/option_text"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnHSwing"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/hswing"
                android:textColor="@color/option_text"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Extras -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/extras_title"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTurbo"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/turbo"
                android:textColor="@color/option_text"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnEco"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/eco"
                android:textColor="@color/option_text"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnHealth"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/health"
                android:textColor="@color/option_text"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnDisplay"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/light"
                android:textColor="@color/option_text"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Room temperature -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <Button
                android:id="@+id/btnRoomMinus"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/minus"
                android:textColor="@color/text_bright"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.6"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtRoom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/temp_placeholder"
                    android:textColor="@color/text_bright"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/room_temp_label"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnRoomPlus"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/btn_option"
                android:stateListAnimator="@null"
                android:text="@string/plus"
                android:textColor="@color/text_bright"
                android:textSize="18sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="18dp"
            android:text="@string/footer_note"
            android:textColor="@color/text_dim"
            android:textSize="11sp" />
    </LinearLayout>
</ScrollView>
